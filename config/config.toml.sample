# Copy this file to:
#   $XDG_CONFIG_HOME/taskforce/config.toml
# or, if XDG_CONFIG_HOME is unset:
#   ~/.config/taskforce/config.toml

# Legacy SQLite path. Prefer [backend].sqlite_path for new configs.
# sqlite_path = "/home/<yourname>/.local/share/taskforce/taskforce.db"

[backend]
kind = "sqlite"
# sqlite_path = "/home/<yourname>/.local/share/taskforce/taskforce.db"

[server]
# host = "127.0.0.1"
# port = 9090  # Optional. Omit this to let taskforce choose a free port.
